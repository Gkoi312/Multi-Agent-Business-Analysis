# -----------------------------
# App runtime (required)
# -----------------------------
# Choose one: openai | google | groq
LLM_PROVIDER=openai

# Unified LLM params
LLM_MODEL_NAME=qwen-plus
LLM_TEMPERATURE=0
# Use 8192+ for full merged reports; 2048 often truncates the last ## Sources rows mid-line.
LLM_MAX_OUTPUT_TOKENS=8192

# For OpenAI-compatible endpoints (optional for openai provider)
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Provider-specific keys
GOOGLE_API_KEY=
GROQ_API_KEY=

# Web search (required for interview generation)
TAVILY_API_KEY=

# Frontend / backend split runtime
APP_ROOT=backend
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_MAX_AGE=604800
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# -----------------------------
# Experimental scripts (optional)
# Used by local helper scripts such as s_full.py
# -----------------------------
ANTHROPIC_BASE_URL=
MODEL_ID=
