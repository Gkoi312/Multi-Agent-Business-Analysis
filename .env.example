# -----------------------------
# App runtime (required)
# -----------------------------
# Choose one: openai | google | groq
LLM_PROVIDER=openai

# Unified LLM params
LLM_MODEL_NAME=qwen-plus
LLM_TEMPERATURE=0
LLM_MAX_OUTPUT_TOKENS=2048

# For OpenAI-compatible endpoints (optional for openai provider)
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Provider-specific keys
GOOGLE_API_KEY=
GROQ_API_KEY=

# Web search (required for interview generation)
TAVILY_API_KEY=

# Embedding params (optional)
EMBEDDING_MODEL_NAME=models/text-embedding-004

# -----------------------------
# CI/CD and cloud deployment (optional)
# -----------------------------
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

ACR_USERNAME=
ACR_PASSWORD=

STORAGE_ACCOUNT_NAME=
STORAGE_ACCOUNT_KEY=

# -----------------------------
# Experimental scripts (optional)
# Used by local helper scripts such as s_full.py
# -----------------------------
ANTHROPIC_BASE_URL=
MODEL_ID=
